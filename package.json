{
  "name": "account-briefs-for-outreach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch --mode development --config vite.config.ts\" \"vite build --watch --mode development --config vite.content.config.ts\"",
    "build": "tsc --noEmit && vite build --config vite.config.ts && vite build --config vite.content.config.ts",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "idb": "^8.0.3",
    "openai": "^5.10.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "read-excel-file": "^9.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
